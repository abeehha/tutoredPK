PORT=4001
SUPABASE_TEST_PORT=5050

# PostgreSQL/Supabase database connection string
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>

# App secret used by backend (set your own secure value)
JWT_SECRET=change_me_to_a_secure_secret

# Supabase project settings
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Auth redirect URLs
SUPABASE_EMAIL_REDIRECT_TO=http://localhost:4001
SUPABASE_PASSWORD_RESET_REDIRECT_TO=http://localhost:4001

# Pricing / limits
SUBSCRIPTION_PRICE_1M=2000
SUBSCRIPTION_PRICE_3M=5000
SUBSCRIPTION_PRICE_1Y=18000
ACADEMY_SUBSCRIPTION_PRICE_1M=20000
SESSION_PRICE=1000
TOPUP_MAX_AMOUNT=100000
